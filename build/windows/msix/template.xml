<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="tavlio.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Lazarillo Labs\Tavlio">
    </Installer>
    <PackageInformation
        PackageName="Tavlio"
        PackageDisplayName="Tavlio"
        PublisherName="CN=Lazarillo Labs"
        PublisherDisplayName="Lazarillo Labs"
        Version="0.1.0.0"
        PackageDescription="A cross-platform, fully local desktop app for tracking and displaying users' digital habits">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.example.tavlio"
                Description="A cross-platform, fully local desktop app for tracking and displaying users' digital habits"
                DisplayName="Tavlio"
                ExecutableName="tavlio.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Tavlio</DisplayName>
            <PublisherDisplayName>Lazarillo Labs</PublisherDisplayName>
            <Description>A cross-platform, fully local desktop app for tracking and displaying users' digital habits</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="tavlio.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
